# ─── Base de datos (Neon PostgreSQL) ─────────────────────────────────────────
# Copia este valor desde el dashboard de Neon: Project > Connection string
# Formato: postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require
DATABASE_URL=""

# ─── Inmovilla ────────────────────────────────────────────────────────────────
# OPCIÓN A (recomendada): Feed XML diario — sin autenticación extra, sin rate limits.
# Test:       https://procesos.inmovilla.com/xml/xml2demo/{numagencia}-web.xml
# Producción: https://procesos.inmovilla.com/xml/xml2/{numagencia}-web.xml
# Si esta variable está definida, se usa el XML. Si no, se usa la API REST.
INMOVILLA_XML_URL=""

# OPCIÓN B: API REST v1
# Token del CRM → Configuración → API → Token (cadena hex de 32 chars).
INMOVILLA_TOKEN=""
# Pausa entre llamadas de detalle (ms). Default: 12000. La API permite 50 req/10 min.
INMOVILLA_SYNC_DELAY_MS="12000"

# Secret que Inmovilla incluirá en la cabecera x-inmovilla-secret del webhook.
# Pon cualquier cadena larga y aleatoria; configúrala también en Inmovilla.
# Genera una con: openssl rand -base64 32
INMOVILLA_WEBHOOK_SECRET=""

# ─── Cron de sincronización ───────────────────────────────────────────────────
# Protege el endpoint GET /api/sync para que solo Vercel Cron (o tú) puedan llamarlo.
# Genera un valor con: openssl rand -base64 32
CRON_SECRET=""

# ─── Panel de administración ──────────────────────────────────────────────────
# Acceso a /admin — define usuario y contraseña para el panel
ADMIN_USERNAME="admin"
ADMIN_PASSWORD=""

# Clave secreta para firmar las cookies de sesión del admin
# Genera una con: openssl rand -base64 32
ADMIN_SECRET=""
