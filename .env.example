# ─── Base de datos (Neon PostgreSQL) ─────────────────────────────────────────
# Copia este valor desde el dashboard de Neon: Project > Connection string
# Formato: postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require
DATABASE_URL=""

# ─── Inmovilla ────────────────────────────────────────────────────────────────
# Credenciales de la API de Inmovilla (te las proporcionan ellos)
# Sin estas variables la web muestra los datos de ejemplo
INMOVILLA_API_URL=""
INMOVILLA_API_KEY=""

# Secret que Inmovilla incluirá en cada webhook (lo defines tú, lo configuras en Inmovilla)
# Genera uno con: openssl rand -base64 32
INMOVILLA_WEBHOOK_SECRET=""

# ─── Cron de sincronización ───────────────────────────────────────────────────
# Protege el endpoint /api/sync
# Genera uno con: openssl rand -base64 32
CRON_SECRET=""
